{
  "name": "librebugbounty/librebugbounty",
  "description": "LibreBugBounty is a local OpenBugBounty-style alternative for reflected XSS intake, browser verification, and screenshots.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "doctrine/doctrine-bundle": "^2.13",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "doctrine/orm": "^3.3",
    "symfony/console": "^7.2",
    "symfony/cache": "^7.2",
    "symfony/dependency-injection": "^7.2",
    "symfony/doctrine-bridge": "^7.2",
    "symfony/dotenv": "^7.2",
    "symfony/framework-bundle": "^7.2",
    "symfony/filesystem": "^7.2",
    "symfony/http-client": "^7.2",
    "symfony/string": "^7.2",
    "symfony/uid": "^7.2",
    "symfony/validator": "^7.2",
    "symfony/yaml": "^7.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "symfony/phpunit-bridge": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.3.30"
    },
    "allow-plugins": {
      "symfony/flex": true
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.2.*"
    }
  }
}
