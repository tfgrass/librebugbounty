#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)
PROJECT_NAME=$(awk '/^name:/ { print $2; exit }' "$ROOT_DIR/.ddev/config.yaml")
BASE_URL="${BASE_URL:-https://${PROJECT_NAME}.ddev.site}"
CONTAINER="ddev-${PROJECT_NAME}-playwright"
OUTPUT_DIR="/var/www/html/docs/screenshots"
DB_PATH="$ROOT_DIR/storage/database/app.sqlite"

DETAIL_FINDING_ID=$(sqlite3 -noheader "$DB_PATH" "SELECT f.id
FROM finding f
JOIN evidence e ON e.finding_id = f.id AND e.kind = 'screenshot'
WHERE f.status IN ('new', 'verified', 'reported')
ORDER BY CASE f.status WHEN 'new' THEN 0 WHEN 'verified' THEN 1 WHEN 'reported' THEN 2 ELSE 3 END, COALESCE(f.submitted_at, f.created_at) DESC
LIMIT 1;")

if [ -z "$DETAIL_FINDING_ID" ]; then
  ddev exec php bin/console app:screenshot:missing --limit 1 --browser chromium
  DETAIL_FINDING_ID=$(sqlite3 -noheader "$DB_PATH" "SELECT f.id
FROM finding f
JOIN evidence e ON e.finding_id = f.id AND e.kind = 'screenshot'
WHERE f.status IN ('new', 'verified', 'reported')
ORDER BY CASE f.status WHEN 'new' THEN 0 WHEN 'verified' THEN 1 WHEN 'reported' THEN 2 ELSE 3 END, COALESCE(f.submitted_at, f.created_at) DESC
LIMIT 1;")
fi

if [ -z "$DETAIL_FINDING_ID" ]; then
  DETAIL_FINDING_ID=$(sqlite3 -noheader "$DB_PATH" "SELECT f.id
FROM finding f
JOIN evidence e ON e.finding_id = f.id AND e.kind = 'screenshot'
ORDER BY COALESCE(f.submitted_at, f.created_at) DESC
LIMIT 1;")
fi

if [ -z "$DETAIL_FINDING_ID" ]; then
  echo "No screenshot-bearing finding found."
  exit 1
fi

docker exec -i -w /var/www/html/playwright-worker "$CONTAINER" env \
  BASE_URL="$BASE_URL" \
  OUTPUT_DIR="$OUTPUT_DIR" \
  DETAIL_FINDING_ID="$DETAIL_FINDING_ID" \
  node - <<'NODE'
const fs = require('fs');
const path = require('path');
const { chromium } = require('playwright');

const baseUrl = process.env.BASE_URL || 'https://librebugbounty.ddev.site';
const outputDir = process.env.OUTPUT_DIR || '/var/www/html/docs/screenshots';
const detailFindingId = process.env.DETAIL_FINDING_ID || '';
const overviewPath = path.join(outputDir, 'overview-redacted.png');
const detailPath = path.join(outputDir, 'detail-redacted.png');

function ensureDir(dir) {
  fs.mkdirSync(dir, { recursive: true });
}

async function redact(page) {
  await page.addStyleTag({
    content: `
      html, body { background: #f8f4ec !important; }
      .row-link code,
      .detail-list dd,
      .shot-card img,
      .shot-card figcaption code,
      table tbody td code {
        filter: blur(8px) !important;
        color: transparent !important;
        text-shadow: 0 0 12px rgba(31, 26, 22, 0.7) !important;
        user-select: none !important;
      }
      .shot-card {
        position: relative !important;
        overflow: hidden !important;
      }
      .shot-card img {
        -webkit-mask-image: linear-gradient(to bottom, transparent 0%, transparent 10%, black 10%, black 100%) !important;
        mask-image: linear-gradient(to bottom, transparent 0%, transparent 10%, black 10%, black 100%) !important;
      }
      .panel { box-shadow: none !important; }
    `,
  });
}

(async () => {
  ensureDir(outputDir);

  const browser = await chromium.launch({ headless: true });
  const context = await browser.newContext({
    ignoreHTTPSErrors: true,
    viewport: { width: 1440, height: 900 },
  });
  const page = await context.newPage();

  await page.goto(baseUrl, { waitUntil: 'networkidle' });
  await redact(page);
  await page.screenshot({ path: overviewPath, fullPage: true });

  if (!detailFindingId) {
    throw new Error('No screenshot-bearing finding id available.');
  }

  await page.goto(new URL(`/findings/${detailFindingId}`, baseUrl).toString(), { waitUntil: 'networkidle' });
  await redact(page);
  await page.screenshot({ path: detailPath, fullPage: true });

  await browser.close();
  console.log(`Wrote ${overviewPath}`);
  console.log(`Wrote ${detailPath}`);
})().catch((error) => {
  console.error(error.stack || error.message || String(error));
  process.exit(1);
});
NODE
